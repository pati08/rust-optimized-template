# Build args:
# OPTIMIZE=false (default): Fast debug builds
# OPTIMIZE=true: Production release builds
ARG OPTIMIZE=false

FROM lukemathwalker/cargo-chef:latest-rust-1 AS chef
WORKDIR /{{package-name}}

# Install build dependencies
RUN apt-get update && apt-get install -y \
  clang \
  mold \
  && rm -rf /var/lib/apt/lists/*

# ============ TOOLCHAIN & FETCH STAGE ============
# Install nightly toolchain and pre-fetch all dependencies
# This layer caches the rust compiler download and all crates
FROM chef AS fetch
COPY rust-toolchain.toml .
# Install the nightly toolchain specified in rust-toolchain.toml
RUN rustup toolchain install nightly && rustup default nightly

# ============ PLANNER STAGE ============
FROM fetch AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

# ============ BUILDER STAGE ============
FROM fetch AS builder
ARG OPTIMIZE=false

COPY --from=planner /{{package-name}}/recipe.json recipe.json

# Build dependencies - all crates are already fetched, this just compiles them
RUN if [ "$OPTIMIZE" = "true" ]; then \
  cargo chef cook --release --recipe-path recipe.json; \
  else \
  cargo chef cook --recipe-path recipe.json; \
  fi

COPY . .

RUN touch src/main.rs

# Build the application
RUN if [ "$OPTIMIZE" = "true" ]; then \
  cargo build --release --bin {{package-name}} && \
  cp target/release/{{package-name}} /tmp/{{package-name}}; \
  else \
  cargo build --bin {{package-name}} && \
  cp target/debug/{{package-name}} /tmp/{{package-name}}; \
  fi

# ============ RUNTIME STAGE ============
FROM debian:trixie-slim AS runtime
WORKDIR /{{package-name}}

RUN apt-get update && apt-get install -y \
  python3 \
  black \
  bash \
  shfmt \
  ruby \
  perl \
  perltidy \
  nodejs \
  npm \
  lua5.4 \
  && npm install -g prettier \
  && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1001 -s /bin/bash appuser

COPY --from=builder /tmp/{{package-name}} /usr/local/bin/{{package-name}}

RUN chown -R appuser:appuser /{{package-name}}
USER appuser

ENTRYPOINT ["/usr/local/bin/{{package-name}}"]
